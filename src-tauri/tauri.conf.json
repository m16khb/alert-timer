{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AlertTimer",
  "version": "0.1.0",
  "identifier": "com.alerttimer.desktop",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AlertTimer",
        "url": "index.html",
        "width": 1080,
        "height": 720,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "overlay",
        "title": "AlertTimer Overlay",
        "url": "overlay.html",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "focus": false
      },
      {
        "label": "mini",
        "title": "AlertTimer Mini",
        "url": "mini.html",
        "width": 340,
        "height": 220,
        "minWidth": 300,
        "minHeight": 180,
        "resizable": false,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Skill timer overlay",
    "longDescription": "A lightweight tray timer overlay for skill recast reminders.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
